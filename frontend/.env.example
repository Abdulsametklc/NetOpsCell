# Dev: boş bırak → Vite proxy (incident :8002, game :8004, auth/ws :8000 Gateway)
# Gateway artık hazır (bkz. gateway/), bu yüzden varsayılan gerçek backend'e
# bağlanır. Backend'siz frontend-only geliştirme için AUTH_MOCK=true yapıp
# WS_MOCK=true bırakın (WS gerçek imzalı JWT gerektirir, mock token'la çalışmaz).
VITE_API_BASE_URL=

VITE_USE_AUTH_MOCK=false
VITE_USE_WS_MOCK=false

# Kişi 2 Incident + Gamification hazır → canlı
VITE_USE_INCIDENT_MOCK=false
VITE_USE_GAME_MOCK=false
# Mesaj endpoint'i gelince false
VITE_USE_MESSAGE_MOCK=true
# Stats/audit/personnel API gelince false
VITE_USE_DASHBOARD_MOCK=true

# Auth mock iken Incident status için X-User-Id/Role enjekte edilir
# VITE_INJECT_USER_HEADERS=true

# VITE_WS_URL=ws://localhost:8000/api/v1/ws/notifications
