SERVICE_NAME=ai-service
DATABASE_URL=postgresql+asyncpg://postgres:postgres@ai-db:5432/ai_db

# LLM entegrasyonu (Anthropic). Bos birakilirsa AI Service otomatik olarak kural tabanli
# fallback'i kullanir (bkz. ARCHITECTURE.md SS8.7) - LLM olmadan da servis calisir.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
LLM_TIMEOUT_SECONDS=4.0
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30.0
